---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import drinking_svg from '../assets/vector_assets/Website-Elements-07.svg';
import speaking_svg from '../assets/vector_assets/Website-Elements-11.svg';
import beige_logo from '../assets/vector_assets/Website-Elements-10.svg';
import how_to_book_svg from '../assets/vector_assets/Website-Elements-02.svg';
import * as service from '../texts/service.md';
const { opening, paragraph_1, list_1} = service.frontmatter;
const { services, expertise, list_2, list_2_sublist_1} = service.frontmatter;
const { list_3, list_4, list_5, list_6 } = service.frontmatter;
---
<BaseLayout title="Service">
    <div class="biege-bg">
        <div class="">

            <div class="relative dark-green-bg z-15 bg-[length:105%_105%]">

                <!-- Opening question -->
                <div class="relative text-white z-15 -mb-[5px] flex flex-col items-center justify-center">
                    <div class="w-full p-4 md:p-20 xl:p-20">
                        <h2 class="uppercase font-bold global-sub-header-text">{opening}</h2>
                        <p class="text-left mt-2 md:mt-3 xl:mt-10 global-paragraph-text"><Fragment set:html={paragraph_1}/></p>
                        <ul class="text-left mt-[5px] global-paragraph-text pl-[35px] list-disc">{list_1.map((item: string) => ( <li class="pt-[6px]">{item}</li> ))} </ul>
                    </div>
                </div>
            </div>
            <div class="relative dark-green-bg z-4 h-[280px] tablet:h-[350px] md:h-[550px] xl:h-[720px]"></div>
           
            <!-- WHAT IS SPEECH PATHOLOGY -->
            <div class="green-bg z-1">
                <div class="relative w-full z-15 mt-[-280px] tablet:mt-[-390px] md:mt-[-550px] xl:mt-[-720px] tablet:h-[350] pb-[100px] mobile:pb-[calc(70vw-110px)] md:pb-[150px] pd:mb-[0px] bg-[position:-20vw_-20px] md:bg-[position:-15vw_-60px] xl:bg-[position:0_-150px] flex items-center justify-center px-1 py-1 bg-no-repeat bg-[length:120%_auto] md:bg-[length:115%_auto] xl:bg-[length:100%_auto] bg-[url('../assets/vector_assets/Website-Elements-04.svg')] ">
                    
                    <!-- Content wrapper: full height, flex column -->
                    <div class="z-15 w-full flex flex-col space-y-1 xl:pb-10">
                    
                        <!-- Services Provided -->
                        <div class="relative flex flex-row items-center justify-center w-full px-2 md:px-6 xl:px-12 mt-[calc(20vw-25px)] md:mt-[calc(20vw-70px)] xl:mt-[calc(20vw-80px)] text-left md:text-[0.37rem] xl:text-[1.43rem]">
                            <h1 class="w-full global-header-text text-center"> {services} </h1>
                        </div>

                        <!-- Service Information -->
                        <div class="flex flex-col tablet:flex-row justify-center items-stretch w-full">

                            <!-- Left Text-->
                            <div class="ml-[20px] w-[calc(50vw+100px)] md:w-[520px] xl:w-[850px] h-[230px] md:h-[700px] xl:h-[1000px] z-0 -mr-2">
                                <h3 class="w-full global-sub-header-text font-semibold mt-[1px] md:mt-[40px] xl:mt-[60px] mb-[2px] md:mb-[10px] xl:mb-[25px]" class="">{expertise}</h3>
                                <p class="global-paragraph-text"><Fragment set:html={service.frontmatter.paragraph_2}/></p>
                                <ul class="global-paragraph-text pl-[35px] list-disc"> {list_2.map((list: string, index: number) => ( <li class="pt-[4px]"><Fragment set:html={list}/>{ index === 0 ? list_2_sublist_1.map((sub_list: string) => (<ul class="pl-[35px] list-disc"><li class="px-2 pt-[1px]">{sub_list}</li></ul>)) : ""} </li> ))} </ul>
                            </div>

                            <!-- Right SVG -->  
                            <div class="flex w-[200px] md:w-[220px] xl:w-[550px] z-10">
                                <Image class="px-[30px] md:px-0 translate-y-[240px] tablet:translate-y-[calc(50vw-60px)] md:translate-y-[-100px]" src={drinking_svg} alt="Drinking Man. Speechie, Speech, Therapist, SLT, Aphasia, Voice, Parkinsons Disease, Speak Out, articulation, remote" />
                                <Image class="px-[30px] md:px-0 translate-x-[-30px] translate-y-[240px] tablet:translate-x-[-180px] tablet:translate-y-[calc(50vw-190px)] md:translate-y-[120px]" src={speaking_svg} alt="Speaking Women. Speechie, Speech, Therapist, SLT, Aphasia, Voice, Parkinsons Disease, Speak Out, articulation, remote" />
                            </div>
                            
                        </div>

                    </div>
                </div>
            </div>
            <div class="beige-bg relative z-10 h-[420px] w-100vw -translate-y-[320px] -mb-[60px] tablet:hidden"></div>
            <div class="green-bg text-white relative z-05 h-[300px] mobile:h-[400px] w-full -translate-y-[calc(70vw-150px)] mobile:-translate-y-[calc(70vw-10px)] -mb-[290px] mobile:-mb-[calc(70vw-50px)] -mt-[250px] mobile:-mt-[250px] tablet:hidden bg-[position:-20vw_calc(20vw-300px)] flex items-center justify-center px-1 py-1 bg-no-repeat bg-[length:120%_auto] bg-[url('../assets/vector_assets/Website-Elements-04.svg')] " />
            
            <!-- Pretty boxes -->
            <div class="green-bg py-[50px] mobile:py-[30px] -mt-[5px] mobile:-mt-[390px] tablet:mt-[-5px] z-15 ">
                
                <!-- Areas of services -->
                <div class="flex flex-col md:flex-row justify-center items-stretch w-full gap-y-1 md:gap-x-2 px-4 md:px-6 xl:px-16 py-2">

                    <!-- Left Box -->
                    <div class="relative w-full md:w-[45%] dark-green-bg rounded-2xl text-white p-4 md:p-6 xl:p-8">

                        <!-- Top-left logo -->
                        <Image src={beige_logo} alt="Beige Colored Logo" class="absolute top-0 left-0 w-12 md:w-24 -translate-y-2/3 -translate-x-[45%]" />
                        <h3 class="global-sub-header-text font-semibold mb-4 uppercase"> {service.frontmatter.content_3_title_1} </h3>
                        <ul class="global-paragraph-text space-y-[0.2rem] pl-[35px] list-disc"> {list_3.map((list: string) => ( <li><Fragment set:html={list} /></li> ))} </ul>
                    
                    </div>

                    <!-- Right Box -->
                    <div class="relative w-full md:w-[45%] dark-green-bg rounded-2xl text-white p-4 md:p-6 xl:p-8">

                        <!-- Bottom-right logo -->
                        <Image src={beige_logo} alt="Beige Colored Logo" class="absolute bottom-0 right-0 w-12 md:w-24 translate-y-1/3 translate-x-1/3" />
                        <h3 class="global-sub-header-text font-semibold mb-4 uppercase"> {service.frontmatter.content_3_title_2} </h3>
                        <ul class="global-paragraph-text space-y-[0.2rem] pl-[35px] list-disc"> {list_4.map((list: string) => ( <li><Fragment set:html={list} /></li> ))} </ul>

                    </div>
                </div>
            </div>

            <!-- SIGNS OF NEEDING SUPPORT -->
            <div class="biege-bg relative z-10 w-full h-[450px] md:h-[650px] xl:h-[800px] flex items-center justify-center px-6 py-2 -mt-[5px] -mr-[5px] bg-no-repeat bg-[position:100%_1%] bg-[length:50%_auto] bg-[url('../assets/vector_assets/Website-Elements-03.svg')]">
                <div class="w-full max-w-screen-[90px] mt-1 md:mt-20 xl:mt-30">
                    <h1 class="global-header-text text-center md:text-left xl:py-8">{service.frontmatter.content_4_title_1}</h1>
                    <div class="flex flex-col md:flex-row gap-y-2 md:gap-x-12 w-full">

                        <!-- Left Box -->
                        <div class="relative w-full md:w-1/2 p-2 md:p-4 xl:pt-6 mt-3 ">

                            <!-- Top-left logo -->
                            <h2 class="global-sub-header-text font-semibold uppercase mb-1">{service.frontmatter.content_4_title_2}</h2>
                            <p class="global-paragraph-text mt-2"><Fragment set:html={service.frontmatter.paragraph_3}/></p>
                            <ul class="global-paragraph-text pl-[35px] list-disc"> {list_5.map((list: string) => ( <li><Fragment set:html={list}/></li> ))} </ul>
                        
                        </div>

                        <!-- Right Box -->
                        <div class="relative w-full md:w-1/2 p-2 md:p-6 xl:p-8 ">

                            <!-- Bottom-right logo -->
                            <h2 class="global-sub-header-text font-semibold uppercase mb-1"><Fragment set:html={service.frontmatter.content_4_title_3}/></h2>
                            <p class="global-paragraph-text mt-2"><Fragment set:html={service.frontmatter.paragraph_4}/></p>
                            <ol class="global-paragraph-text pl-[35px] list-disc"> {list_6.map((list: string) => ( <li><Fragment set:html={list}/></li> ))} </ol>

                        </div>
                    </div>
                </div>
            </div>
            <div class="w-1/2 -mt-[50px] -mb-[5px] -ml-[5px]">
                <Image src={how_to_book_svg} alt="Dark Green Colored seperator. Speechie, Speech, Therapist, SLT, Aphasia, Voice, Parkinsons Disease, Speak Out, articulation, remote" class="w-full h-full" />
            </div>
        </div>
    </div>
</BaseLayout>
